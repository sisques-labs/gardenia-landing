---
import Icon from './Icon.astro';
import { ui, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
const year = new Date().getFullYear();
---

<footer class="border-t border-rule/60 bg-paper-2">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[1.4fr_2fr]">
      <div class="max-w-xs">
        <a href="#top" class="flex items-center gap-2 text-ink">
          <span class="grid h-9 w-9 place-items-center rounded-lg bg-forest text-white">
            <Icon name="leaf" class="h-5 w-5" />
          </span>
          <span class="font-serif text-xl tracking-tight">Gardenia</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-ink-2">{t.footer.tagline}</p>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
        {
          t.footer.columns.map((col) => (
            <div>
              <h3 class="eyebrow">{col.heading}</h3>
              <ul class="mt-3 space-y-2">
                {col.links.map((link) => (
                  <li>
                    <a
                      href="#"
                      class="text-sm text-ink-2 transition-colors hover:text-forest"
                    >
                      {link}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="dashed-rule mt-12 flex flex-col items-center justify-between gap-2 pt-6 sm:flex-row"
    >
      <p class="text-xs text-ink-3">© {year} Gardenia. {t.footer.rights}</p>
      <p class="text-xs text-ink-3">{t.footer.madeWith}</p>
    </div>
  </div>
</footer>
