---
import Icon from './Icon.astro';
import { ui, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
---

<section class="border-t border-rule/60 bg-paper">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 lg:py-24">
    <div
      class="relative overflow-hidden rounded-2xl border border-forest-3 bg-forest px-6 py-14 text-center sm:px-12 sm:py-20"
    >
      <!-- decorative grain -->
      <div
        class="pointer-events-none absolute inset-0 opacity-20"
        style="background-image: radial-gradient(circle at 1px 1px, var(--white) 1px, transparent 0); background-size: 22px 22px;"
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-2xl">
        <span
          class="text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-forest-bg"
        >
          {t.cta.eyebrow}
        </span>
        <h2 class="mt-3 font-serif text-4xl tracking-tight text-white sm:text-5xl">
          {t.cta.title}
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-forest-bg">{t.cta.subtitle}</p>

        <div class="mt-9 flex flex-col items-center gap-3">
          <a
            href="#"
            class="inline-flex h-12 items-center gap-2 rounded-full bg-paper px-7 text-base font-medium text-forest shadow-sm transition-transform hover:-translate-y-0.5"
          >
            {t.cta.button}
            <Icon name="arrow-right" class="h-[18px] w-[18px]" />
          </a>
          <p class="font-mono text-xs text-forest-bg/90">{t.cta.note}</p>
        </div>
      </div>
    </div>
  </div>
</section>
