---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import LangToggle from './LangToggle.astro';
import { ui, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
---

<header
  class="sticky top-0 z-40 border-b border-rule/70 bg-paper/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5 sm:px-8"
    aria-label="Primary"
  >
    <a href="#top" class="flex items-center gap-2 text-ink">
      <span class="grid h-9 w-9 place-items-center rounded-lg bg-forest text-white">
        <Icon name="leaf" class="h-5 w-5" />
      </span>
      <span class="font-serif text-xl tracking-tight">Gardenia</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      <a
        href="#features"
        class="text-sm text-ink-2 transition-colors hover:text-forest"
      >{t.nav.features}</a>
      <a
        href="#how"
        class="text-sm text-ink-2 transition-colors hover:text-forest"
      >{t.nav.how}</a>
    </div>

    <div class="flex items-center gap-2">
      <ThemeToggle locale={locale} />
      <LangToggle locale={locale} />
      <a
        href="#"
        class="ml-1 hidden h-9 items-center rounded-full bg-forest px-4 text-sm font-medium text-white shadow-sm transition-colors hover:bg-forest-2 sm:inline-flex"
      >
        {t.nav.cta}
      </a>
    </div>
  </nav>
</header>
