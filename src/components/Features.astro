---
import Icon from './Icon.astro';
import { ui, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];

const accents: Record<string, string> = {
  leaf: 'bg-forest-bg text-forest',
  map: 'bg-honey-bg text-honey-2',
  clipboard: 'bg-sage-bg text-forest',
  basket: 'bg-terra-bg text-terracotta',
  calendar: 'bg-forest-bg text-forest',
  bell: 'bg-honey-bg text-honey-2',
};
---

<section id="features" class="border-t border-rule/60 bg-paper">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 lg:py-28">
    <div class="max-w-2xl">
      <span class="eyebrow">{t.features.eyebrow}</span>
      <h2 class="mt-3 font-serif text-4xl tracking-tight text-ink sm:text-5xl">
        {t.features.title}
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-ink-2">{t.features.subtitle}</p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        t.features.items.map((f) => (
          <article class="card group p-6 transition-shadow hover:shadow-md">
            <span
              class={`grid h-11 w-11 place-items-center rounded-lg ${accents[f.icon]}`}
            >
              <Icon name={f.icon} class="h-[22px] w-[22px]" />
            </span>
            <h3 class="mt-5 font-serif text-xl text-ink">{f.title}</h3>
            <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-2">{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
