---
import { ui, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
---

<section id="how" class="paper-grain border-t border-rule/60">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 lg:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">{t.how.eyebrow}</span>
      <h2 class="mt-3 font-serif text-4xl tracking-tight text-ink sm:text-5xl">
        {t.how.title}
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-ink-2">{t.how.subtitle}</p>
    </div>

    <ol class="relative mt-16 grid gap-10 md:grid-cols-3 md:gap-6">
      <!-- connecting dashed line on desktop -->
      <div
        class="dashed-rule absolute left-0 right-0 top-7 hidden md:block"
        aria-hidden="true"
      >
      </div>

      {
        t.how.steps.map((s) => (
          <li class="relative flex flex-col items-center text-center md:items-start md:text-left">
            <span class="relative z-10 grid h-14 w-14 place-items-center rounded-full border border-forest-3 bg-paper font-serif text-xl text-forest shadow-sm">
              {s.num}
            </span>
            <h3 class="mt-5 font-serif text-2xl text-ink">{s.title}</h3>
            <p class="mt-2 max-w-xs text-[0.95rem] leading-relaxed text-ink-2">
              {s.body}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
